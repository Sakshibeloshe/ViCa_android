<?xml version="1.0" encoding="utf-8"?>
<!--
    Fallback launcher icon for devices below API 26 (not applicable since minSdk=26,
    but AAPT requires at least one non-anydpi mipmap entry to resolve @mipmap/ic_launcher).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="48"
    android:viewportHeight="48">

    <!-- Black background -->
    <path
        android:fillColor="#0A0A0F"
        android:pathData="M0,0 H48 V48 H0 Z" />

    <!-- Gold V -->
    <path
        android:fillColor="#D4A843"
        android:pathData="M10,10 L24,38 L38,10 L32,10 L24,28 L16,10 Z" />
</vector>
